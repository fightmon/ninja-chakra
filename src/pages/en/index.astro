---
import Base from '../../layouts/Base.astro';
---
<Base title="Blockyusha — Woodoku × Card-Battle RPG" path="/en/" navActive="home" lang="en" alt="/">

<!-- HERO -->
<section class="hero">
  <span class="decor" style="left:6%;top:12%">🔥</span>
  <span class="decor" style="right:8%;top:16%">💧</span>
  <span class="decor" style="left:12%;top:46%">⚡</span>
  <span class="decor" style="right:10%;top:52%">🍃</span>
  <div class="wrap">
    <h1 class="logo">BLOCKYUSHA</h1>
    <p class="en">塊頭勇者</p>
    <p class="slogan">Drag blocks, clear lines, unleash big attacks——<br>collect adorable <b>blocky animal heroes</b>!</p>
    <img class="heroart" src="/play/art/cards/c15_full.webp" alt="Blockyusha hero — Taiwan Clouded Leopard" width="300" />
    <a class="cta" href="/play/">▶ Play Now</a>
    <p class="free">No download · Play right in your browser 📱</p>
    <div class="kw"><span># Block Puzzle</span><span># Card-Battle RPG</span><span># Card Collecting</span><span># 5-Element Counters</span></div>
  </div>
</section>

<!-- CHARACTER -->
<section class="character" id="character">
  <div class="wrap">
    <p class="eyebrow">Character</p>
    <h2 class="h2">Meet the Heroes</h2>
    <div class="cards">
      <div class="char" style="--el:var(--fire)">
        <div class="ring"><img src="/play/art/cards/c15_thumb.webp" alt="Dawu" /></div>
        <h3>Dawu · Taiwan Clouded Leopard</h3><span class="el">Fire · Leader</span>
        <p>A Fire-type leader inspired by Taiwan's endemic species — one swipe lights up the whole line.</p>
      </div>
      <div class="char" style="--el:var(--water)">
        <div class="ring"><img src="/play/art/cards/c04_thumb.webp" alt="Rippy" /></div>
        <h3>Rippy</h3><span class="el">Water · Healer</span>
        <p>A calm Water-type hero who heals on clears and keeps the whole team's rhythm steady.</p>
      </div>
      <div class="char" style="--el:var(--thunder)">
        <div class="ring"><img src="/play/art/cards/c07_thumb.webp" alt="Buzzo" /></div>
        <h3>Buzzo</h3><span class="el">Thunder · Burst</span>
        <p>The fastest Thunder-type hero — chain clears into a huge burst of damage in an instant.</p>
      </div>
    </div>
    <div style="text-align:center;margin-top:30px"><a class="allbtn" href="/dex/">See all 60 heroes →</a></div>
  </div>
</section>

<!-- GALLERY -->
<section class="gallery" id="gallery">
  <p class="eyebrow">Gallery</p>
  <h2 class="h2">Hero Gallery</h2>
  <div class="strip">
    <img src="/play/art/cards/c01_full.webp" alt="Pyri" loading="lazy" />
    <img src="/play/art/cards/c03_full.webp" alt="Blazu" loading="lazy" />
    <img src="/play/art/cards/c07_full.webp" alt="Buzzo" loading="lazy" />
    <img src="/play/art/cards/c04_full.webp" alt="Rippy" loading="lazy" />
    <img src="/play/art/cards/c11_full.webp" alt="Breezy" loading="lazy" />
    <img src="/play/art/cards/c10_full.webp" alt="Rocco" loading="lazy" />
    <img src="/play/art/cards/c12_full.webp" alt="Gusto" loading="lazy" />
    <img src="/play/art/cards/c15_full.webp" alt="Dawu · Taiwan Clouded Leopard" loading="lazy" />
  </div>
</section>

<!-- FEATURES -->
<section class="features" id="features">
  <div class="wrap">
    <p class="eyebrow">Gameplay</p>
    <h2 class="h2">Game Features</h2>
    <div class="feats">
      <div class="feat"><div class="ic">🧩</div><div><h3>Woodoku Sewn Into an RPG</h3><p>Drag blocks onto a 9×9 board — fill a full row, column, or 3×3 box to clear it. Every clear is an attack.</p></div></div>
      <div class="feat"><div class="ic">🔥</div><div><h3>5-Element Counter Ring</h3><p>Fire → Wind → Thunder → Earth → Water → Fire. Hit a weakness for double damage.</p></div></div>
      <div class="feat"><div class="ic">🐾</div><div><h3>Collect Animal Heroes</h3><p>Cats, dogs, birds, rats, rabbits, fish, and Taiwan's endemic species — build your squad one blocky hero at a time.</p></div></div>
      <div class="feat"><div class="ic">🗼</div><div><h3>Climb the Tower</h3><p>Your board, momentum, and saved element blocks carry into the next stage — it only gets more intense as you climb.</p></div></div>
    </div>
  </div>
</section>

<!-- EVENT / CTA -->
<section class="event">
  <span class="decor" style="left:8%;top:20%">✨</span>
  <span class="decor" style="right:9%;top:60%">✨</span>
  <div class="wrap">
    <img class="ev-art" src="/play/art/cards/c03_full.webp" alt="Blazu" />
    <div class="stars">★★★★★</div>
    <h2>Play now, it's free!</h2>
    <p>No download, no sign-up — one tap and your blocky hero adventure begins.</p>
    <a class="cta2" href="/play/">▶ Play Now</a>
  </div>
</section>

<!-- SOCIAL -->
<section class="social">
  <p class="eyebrow">Community</p>
  <h2 class="h2">Join the Fun</h2>
  <div class="avatars">
    <img src="/play/art/cards/c01_thumb.webp" alt="" />
    <img src="/play/art/cards/c07_thumb.webp" alt="" />
    <img src="/play/art/cards/c11_thumb.webp" alt="" />
    <img src="/play/art/cards/c04_thumb.webp" alt="" />
    <img src="/play/art/cards/c15_thumb.webp" alt="" />
  </div>
  <div class="handle">@blockyusha</div>
  <p>Share the game with friends, collect blocky heroes together, and climb the leaderboard! Follow the dev diary for behind-the-scenes updates.</p>
  <div class="socbtns">
    <a href="/play/">🎮 Play Now</a>
    <a href="/dex/">🐾 Character Dex</a>
    <a href="/devlog/">📖 Dev Log</a>
  </div>
</section>

<style is:global>
.hero{background:radial-gradient(120% 90% at 50% 0%,#fff3cf 0%,var(--sun) 55%,var(--sun2) 130%);padding:38px 0 0;text-align:center;overflow:hidden}
.hero .logo{font-size:clamp(46px,15vw,92px);font-weight:900;letter-spacing:-1px;line-height:1;color:#fff;text-shadow:0 4px 0 #e67e00,0 8px 22px rgba(150,70,0,.35)}
.hero .en{font-size:clamp(14px,4vw,20px);letter-spacing:8px;color:#8a5200;font-weight:800;margin-top:10px}
.hero .slogan{font-size:clamp(16px,4.2vw,20px);color:#5a3a08;font-weight:600;margin:18px auto 0;max-width:22em}
.hero .slogan b{color:#c8340f}
.heroart{width:min(300px,74vw);margin:6px auto -6px;filter:drop-shadow(0 20px 28px rgba(150,70,0,.3))}
.cta{display:inline-block;margin-top:6px;font-weight:900;color:#3a1f00;font-size:clamp(21px,6vw,26px);
  background:linear-gradient(120deg,#fff0b0,#ff8a2a);padding:18px 52px;border-radius:999px;
  box-shadow:0 12px 0 #d96a00,0 20px 30px rgba(180,90,0,.35);transition:transform .12s,box-shadow .12s}
.cta:active{transform:translateY(6px);box-shadow:0 6px 0 #d96a00,0 12px 20px rgba(180,90,0,.35)}
.free{color:#7a4e08;font-size:14px;font-weight:600;margin-top:14px}
.kw{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin:20px auto 0;padding-bottom:44px}
.kw span{font-size:13px;font-weight:700;color:#7a4e08;background:rgba(255,255,255,.55);border-radius:999px;padding:6px 14px}
.decor{position:absolute;pointer-events:none;user-select:none;font-size:26px;opacity:.9;z-index:1}
.eyebrow{font-size:13px;letter-spacing:4px;color:var(--sun2);font-weight:800;text-transform:uppercase;text-align:center;margin-bottom:6px}
.h2{font-size:clamp(26px,7vw,38px);font-weight:900;text-align:center;letter-spacing:-.5px;margin-bottom:26px;
  background:linear-gradient(120deg,#ff8a2a,#ff5a3d);-webkit-background-clip:text;background-clip:text;color:transparent}
.character{background:var(--cream);padding:56px 0}
.cards{display:grid;grid-template-columns:1fr;gap:22px}
.char{background:#fff;border-radius:22px;padding:24px 20px;text-align:center;box-shadow:var(--shadow);border:2px solid #fff}
.char .ring{width:120px;height:120px;margin:0 auto 14px;border-radius:50%;padding:5px;background:var(--el);box-shadow:0 8px 20px rgba(0,0,0,.12)}
.char .ring img{width:100%;height:100%;object-fit:cover;border-radius:50%;background:#fff}
.char h3{font-size:22px;font-weight:900}
.char .el{font-size:13px;font-weight:800;color:#fff;background:var(--el);border-radius:999px;padding:3px 12px;display:inline-block;margin:6px 0 10px}
.char p{font-size:15px;color:var(--ink2);line-height:1.75}
.allbtn{display:inline-block;font-weight:900;font-size:17px;color:#fff;background:linear-gradient(120deg,#ff9a3d,#ff5a3d);padding:14px 34px;border-radius:999px;box-shadow:0 8px 20px rgba(255,90,60,.3)}
.gallery{background:var(--sun);padding:56px 0 60px}
.gallery .h2{background:linear-gradient(120deg,#c85a00,#ff5a3d);-webkit-background-clip:text;background-clip:text;color:transparent}
.strip{display:flex;gap:14px;overflow-x:auto;padding:6px 20px 16px;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch}
.strip img{width:180px;height:180px;object-fit:cover;border-radius:18px;flex:0 0 auto;scroll-snap-align:center;background:#fff;border:4px solid #fff;box-shadow:0 10px 22px rgba(150,90,0,.22)}
.features{background:var(--cream);padding:56px 0}
.feats{display:grid;grid-template-columns:1fr;gap:16px}
.feat{background:#fff;border-radius:20px;padding:24px;box-shadow:var(--shadow);display:flex;gap:16px;align-items:flex-start}
.feat .ic{font-size:36px;flex:0 0 auto;line-height:1}
.feat h3{font-size:19px;font-weight:900;margin-bottom:4px}
.feat p{font-size:15px;color:var(--ink2)}
.event{background:linear-gradient(120deg,#ff9a3d,#ff5a3d);color:#fff;text-align:center;padding:54px 0;overflow:hidden}
.event .stars{font-size:22px;letter-spacing:3px;color:#ffe680}
.event h2{font-size:clamp(24px,6.5vw,34px);font-weight:900;margin:8px 0 10px}
.event p{font-size:16px;opacity:.95;max-width:24em;margin:0 auto 22px}
.event .cta2{display:inline-block;font-weight:900;color:#c8340f;background:#fff;font-size:20px;padding:16px 46px;border-radius:999px;box-shadow:0 10px 0 #d9d0c0,0 18px 26px rgba(120,30,0,.3)}
.event .cta2:active{transform:translateY(6px);box-shadow:0 4px 0 #d9d0c0}
.event .ev-art{width:110px;margin:0 auto 6px}
.social{background:var(--cream);padding:56px 0 40px;text-align:center}
.social .avatars{display:flex;justify-content:center;margin:8px 0 18px}
.social .avatars img{width:56px;height:56px;border-radius:50%;object-fit:cover;border:3px solid #fff;box-shadow:0 4px 12px rgba(0,0,0,.12);margin-left:-12px;background:#fff}
.social .avatars img:first-child{margin-left:0}
.handle{font-size:22px;font-weight:900;color:var(--fire)}
.social p{color:var(--ink2);font-size:15px;margin:6px auto 20px;max-width:24em}
.socbtns{display:flex;flex-wrap:wrap;gap:12px;justify-content:center}
.socbtns a{font-weight:800;font-size:15px;color:var(--ink);background:#fff;border-radius:999px;padding:12px 22px;box-shadow:var(--shadow)}
.socbtns a:hover{color:var(--fire)}
/* dark */
[data-theme="dark"] .char,[data-theme="dark"] .feat{background:#231d14;border-color:#231d14}
[data-theme="dark"] .hero{background:radial-gradient(120% 90% at 50% 0%,#3c2d0d,#2b200a 55%,#1b1305 130%)}
[data-theme="dark"] .hero .logo{color:#ffd977;text-shadow:0 4px 0 #7a4400,0 8px 22px rgba(0,0,0,.55)}
[data-theme="dark"] .hero .en{color:#caa040}
[data-theme="dark"] .hero .slogan{color:#ecd9ac}
[data-theme="dark"] .hero .slogan b{color:#ff8a5a}
[data-theme="dark"] .free{color:#caa040}
[data-theme="dark"] .kw span{background:rgba(255,255,255,.09);color:#ecd9ac}
[data-theme="dark"] .gallery{background:#2a200b}
[data-theme="dark"] .strip img{background:#231d14;border-color:#2c2418}
[data-theme="dark"] .social .avatars img,[data-theme="dark"] .socbtns a{background:#231d14;border-color:#2c2418}
@media(min-width:520px){.feats{grid-template-columns:repeat(2,1fr)}}
@media(min-width:720px){.cards{grid-template-columns:repeat(3,1fr)}.hero{padding-top:52px}}
</style>
</Base>
