/* dark */
[data-theme="dark"] .dp .tag{background:rgba(255,255,255,.08);border-color:rgba(255,178,32,.2);color:#e8d4a8}
[data-theme="dark"] .dp .body blockquote{background:rgba(255,178,32,.1)}
[data-theme="dark"] .dp .body hr{border-top-color:rgba(255,178,32,.16)}
[data-theme="dark"] .dp .ask{background:rgba(255,255,255,.05);border-color:rgba(255,178,32,.28)}
[data-theme="dark"] .dp .demo{background:#231d14;border-color:rgba(255,178,32,.16)}
[data-theme="dark"] .dp .tilt-grid{background:rgba(255,255,255,.05)}
[data-theme="dark"] .dp .bar-track{background:rgba(255,255,255,.08)}
[data-theme="dark"] .dp .foot{border-top-color:rgba(255,178,32,.16)}
</style>

<script is:inline>
const sleep=ms=>new Promise(r=>setTimeout(r,ms));

/* ---- 公平性長條 ---- */
const NET=[['陽 回血',76,'#3dd68c'],['雷 麻痺',75,'#3dd68c'],['火 燒傷',59,'#37b6ff'],['水 填塊',35,'#37b6ff'],['土 搬移',8,'#ff8f4a'],['陰 增傷',4,'#ff8f4a'],['風 消塊',-2,'#ff5c5c']];
(function(){const w=document.getElementById('bars');
  NET.forEach(([lab,v,col])=>{const row=document.createElement('div');row.className='bar-row';
    row.innerHTML='<div class="bar-lab">'+lab+'</div><div class="bar-track"><div class="bar-fill"></div></div><div class="bar-val">'+(v>0?'+':'')+v+'</div>';
    w.appendChild(row);const f=row.querySelector('.bar-fill');f.style.background=col;
    setTimeout(()=>{f.style.width=Math.max(3,v/80*100)+'%';},200);});
})();

/* ---- 土傾斜 demo ---- */
const SZ=5,CELL=34,ELC=['#ff6a3d','#37b6ff','#f0b410','#c8873f','#3fbf54'];
const grid=document.getElementById('tgrid'),arrow=document.getElementById('tarrow');
let blocks=[];
function clearBlocks(){blocks.forEach(b=>b.dom.remove());blocks=[];}
function scatter(){clearBlocks();
  // 保證每欄至少 1 塊(傾斜往下→底排必滿) + 隨機加幾塊
  const cells=[];
  for(let c=0;c<SZ;c++){const r=Math.floor(Math.random()*SZ);cells.push([r,c]);}
  let extra=5;while(extra>0){const r=Math.floor(Math.random()*SZ),c=Math.floor(Math.random()*SZ);
    if(!cells.some(([a,o])=>a===r&&o===c)){cells.push([r,c]);extra--;}}
  cells.forEach(([r,c])=>{const d=document.createElement('div');d.className='tcell';
    d.style.left=c*CELL+'px';d.style.top=r*CELL+'px';d.style.background=ELC[Math.floor(Math.random()*ELC.length)];
    d.style.transform='scale(0)';grid.appendChild(d);blocks.push({r,c,dom:d});
    setTimeout(()=>d.style.transform='scale(1)',20);});}
function tiltDown(){
  for(let c=0;c<SZ;c++){const col=blocks.filter(b=>b.c===c).sort((a,b)=>a.r-b.r);
    col.forEach((b,i)=>{b.r=SZ-col.length+i;b.dom.style.top=b.r*CELL+'px';});}}
function fullRows(){const rs=[];for(let r=0;r<SZ;r++)if(blocks.filter(b=>b.r===r).length===SZ)rs.push(r);return rs;}
async function loop(){
  while(true){
    arrow.innerHTML='&nbsp;';scatter();await sleep(900);
    arrow.textContent='▼ 往下傾斜';tiltDown();await sleep(650);
    const rs=fullRows();const hit=blocks.filter(b=>rs.includes(b.r));
    if(hit.length){hit.forEach(b=>b.dom.classList.add('flash'));await sleep(380);
      hit.forEach(b=>b.dom.classList.add('gone'));await sleep(300);
      blocks=blocks.filter(b=>!hit.includes(b));hit.forEach(b=>b.dom.remove());}
    await sleep(700);
  }
}
loop();
</script>
</Base>
