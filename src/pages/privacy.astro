  .legal h1{font-size:30px;font-weight:900;letter-spacing:-.5px;margin-bottom:6px}
  .legal .meta{font-size:13px;color:var(--ink2);margin-bottom:22px}
  .legal .lead{font-size:16px;background:rgba(255,178,32,.1);border:1px solid rgba(255,178,32,.28);
    border-radius:12px;padding:14px 16px;margin-bottom:26px}
  .legal h2{font-size:19px;font-weight:800;margin:26px 0 8px;padding-top:6px;border-top:1px solid rgba(140,90,20,.14)}
  .legal p{margin:8px 0;font-size:15.5px}
  .legal ul{margin:8px 0 8px 4px;padding-left:20px}
  .legal li{margin:6px 0;font-size:15.5px}
  .legal a{color:var(--fire);text-decoration:underline;font-weight:600}
  .legal .foot{margin-top:34px;font-size:13px;color:var(--ink2);text-align:center}
  [data-theme="dark"] .legal .lead{background:rgba(255,178,32,.08);border-color:rgba(255,178,32,.22)}
</style>
</Base>
