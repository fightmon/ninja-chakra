---
// 全站共用版面：head/SEO/OG + 日夜模式 + 單一來源 nav/footer + 共用 CSS
export interface Props {
  title: string;
  description?: string;
  image?: string;          // OG 圖(絕對或相對 /)；預設 og-image
  path?: string;           // 目前路徑(canonical)，如 '/dex/c15/'
  navActive?: 'dex' | 'devlog' | 'howto' | 'faq' | 'tier' | 'home' | '';
  lang?: 'zh-TW' | 'en';   // 頁面語言；預設繁中
  alt?: string;            // 另一語言版本的路徑；有值才輸出 hreflang 互指
}
const {
  title,
  description,
  image = '/og-image.webp',
  path = '/',
  navActive = '',
  lang = 'zh-TW',
  alt,
} = Astro.props;
const isEn = lang === 'en';
const desc = description ?? (isEn
  ? 'Blockyusha is a free browser game that fuses Woodoku block puzzles with a card-battle RPG: drag blocks to clear lines, unleash 5-element attacks, and collect cute blocky animal heroes. No download — just open your browser and play.'
  : '塊頭勇者 Blockyusha 是一款把 Woodoku 方塊消除縫進轉珠 RPG 的卡片收集手機遊戲：拖方塊消除觸發五屬攻擊，收集可愛的方塊頭動物勇者一路闖塔。免下載，開網頁就能玩。');
const site = Astro.site ?? 'https://blockyusha.com';
const canonical = new URL(path, site).href;
const ogImage = new URL(image, site).href;
// hreflang 互指(只有提供 alt 的頁面才輸出)
const enPath = alt ? (isEn ? path : alt) : null;
const zhPath = alt ? (isEn ? alt : path) : null;
// 語系化 nav
const nav = isEn ? [
  { href: '/dex/',            label: 'Characters',  key: 'dex' },
  { href: '/en/tier-list/',   label: 'Tier List',   key: 'tier' },
  { href: '/en/how-to-play/', label: 'How to Play', key: 'howto' },
  { href: '/en/faq/',         label: 'FAQ',         key: 'faq' },
] : [
  { href: '/dex/',                label: '角色圖鑑', key: 'dex' },
  { href: '/tier-list/',          label: 'Tier 榜',  key: 'tier' },
  { href: '/devlog/how-to-play/', label: '玩法',     key: 'howto' },
  { href: '/faq/',                label: 'FAQ',      key: 'faq' },
  { href: '/devlog/',             label: '日誌',     key: 'devlog' },
];
const brand = isEn ? 'Blockyusha' : '塊頭勇者';
const homeHref = isEn ? '/en/' : '/';
const playLabel = isEn ? 'Play' : '開始遊戲';
const switchHref = alt ?? (isEn ? '/' : '/en/');
const switchLabel = isEn ? '中' : 'EN';
---
<!doctype html>
<html lang={lang}>
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<script is:inline>(function(){try{var t=localStorage.getItem('bytheme')||((window.matchMedia&&matchMedia('(prefers-color-scheme:dark)').matches)?'dark':'light');document.documentElement.setAttribute('data-theme',t);}catch(e){}})();</script>
<title>{title}</title>
<meta name="description" content={desc} />
<link rel="canonical" href={canonical} />
{zhPath && <link rel="alternate" hreflang="zh-TW" href={new URL(zhPath, site).href} />}
{enPath && <link rel="alternate" hreflang="en" href={new URL(enPath, site).href} />}
{enPath && <link rel="alternate" hreflang="x-default" href={new URL(enPath, site).href} />}
<meta name="theme-color" content="#ffd43b" />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="塊頭勇者 Blockyusha" />
<meta property="og:title" content={title} />
<meta property="og:description" content={desc} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:locale" content={isEn ? 'en_US' : 'zh_TW'} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={desc} />
<meta name="twitter:image" content={ogImage} />
<link rel="icon" href="/play/art/cards/c15_thumb.webp" />
<link rel="apple-touch-icon" href="/play/art/cards/c15_thumb.webp" />
</head>
<body>

<header>
  <div class="nav wrap">
    <a class="brand" href={homeHref}>{brand}</a>
    <nav class="links">
      {nav.map((n) => <a href={n.href} class={navActive === n.key ? 'on' : ''}>{n.label}</a>)}
    </nav>
    <div class="navr">
      <a class="langsw" href={switchHref} aria-label="Switch language / 切換語言">{switchLabel}</a>
      <button class="themebtn" type="button" onclick="toggleTheme()" aria-label="切換日夜模式">🌙</button>
      <a class="miniplay" href="/play/">{playLabel}</a>
      <button class="hambtn" type="button" onclick="toggleMenu(this)" aria-label="選單" aria-expanded="false">☰</button>
    </div>
  </div>
  <nav class="mobmenu" id="mobmenu">
    {nav.map((n) => <a href={n.href} class={navActive === n.key ? 'on' : ''}>{n.label}</a>)}
    <a class="mm-play" href="/play/">{playLabel}</a>
  </nav>
</header>

<slot />

<footer>
  {isEn
    ? <><a href="/en/">Home</a><a href="/dex/">Characters</a><a href="/play/">Play</a><a href="/en/faq/">FAQ</a><a href="/terms/">Terms</a><a href="/privacy/">Privacy</a></>
    : <><a href="/">首頁</a><a href="/dex/">角色圖鑑</a><a href="/play/">開始遊戲</a><a href="/devlog/">開發日誌</a><a href="/terms/">服務條款</a><a href="/privacy/">隱私權政策</a></>}
  <div class="cp"><a href="mailto:hello@blockyusha.com">✉ hello@blockyusha.com</a></div>
  <div class="cp">塊頭勇者 Blockyusha · {isEn ? 'in development' : '開發中'} · © 2026 fightmon</div>
</footer>

<script is:inline>
function toggleTheme(){var d=document.documentElement,t=d.getAttribute('data-theme')==='dark'?'light':'dark';
  d.setAttribute('data-theme',t);try{localStorage.setItem('bytheme',t);}catch(e){}
  document.querySelectorAll('.themebtn').forEach(function(b){b.textContent=t==='dark'?'☀️':'🌙';});}
(function(){var t=document.documentElement.getAttribute('data-theme');
  document.querySelectorAll('.themebtn').forEach(function(b){b.textContent=t==='dark'?'☀️':'🌙';});})();
function toggleMenu(btn){var m=document.getElementById('mobmenu');var open=m.classList.toggle('open');
  if(btn){btn.setAttribute('aria-expanded',open);btn.textContent=open?'✕':'☰';}}
document.addEventListener('click',function(e){var m=document.getElementById('mobmenu');
  if(!m||!m.classList.contains('open'))return;
  if(e.target.closest('.mobmenu')||e.target.closest('.hambtn'))return;
  m.classList.remove('open');var b=document.querySelector('.hambtn');if(b){b.setAttribute('aria-expanded','false');b.textContent='☰';}});
</script>

<style is:global>
/* ===== base ===== */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--cream:#fff8ec;--sun:#ffd23b;--sun2:#ffb020;--ink:#2c2114;--ink2:#6b5a41;
  --fire:#ff6a3d;--water:#37b6ff;--thunder:#f0b410;--earth:#c8873f;--wind:#3fbf54;
  --cta1:#ffdf6b;--cta2:#ff8a2a;--shadow:0 12px 30px rgba(140,90,20,.18)}
html{scroll-behavior:smooth}
body{background:var(--cream);color:var(--ink);
  font-family:"Noto Sans TC","PingFang TC","Microsoft JhengHei",system-ui,-apple-system,sans-serif;
  -webkit-font-smoothing:antialiased;line-height:1.6;overflow-x:hidden}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none}
.wrap{max-width:900px;margin:0 auto;padding:0 16px}
/* ===== header / nav (single source) ===== */
header{position:sticky;top:0;z-index:50;background:rgba(255,248,236,.92);backdrop-filter:blur(8px);border-bottom:2px solid rgba(255,178,32,.2)}
.nav{display:flex;align-items:center;justify-content:space-between;height:58px}
.brand{font-size:20px;font-weight:900;letter-spacing:-.5px;
  background:linear-gradient(120deg,#ff8a2a,#ff5a3d);-webkit-background-clip:text;background-clip:text;color:transparent}
.links{display:none;gap:22px;font-size:15px;font-weight:700;color:var(--ink2)}
.links a:hover,.links a.on{color:var(--fire)}
.navr{display:flex;align-items:center;gap:10px}
.langsw{display:grid;place-items:center;min-width:40px;height:40px;padding:0 10px;border-radius:20px;font-size:13px;font-weight:800;
  color:var(--ink2);background:rgba(255,255,255,.55);box-shadow:0 3px 10px rgba(140,90,20,.16);transition:transform .12s,color .12s}
.langsw:hover{color:var(--fire)}
.langsw:active{transform:scale(.9)}
.themebtn{width:40px;height:40px;border:none;border-radius:50%;cursor:pointer;font-size:19px;line-height:1;
  background:rgba(255,255,255,.55);box-shadow:0 3px 10px rgba(140,90,20,.16);transition:transform .12s}
.themebtn:active{transform:scale(.9)}
.miniplay{display:none;background:linear-gradient(120deg,var(--cta1),var(--cta2));color:#3a1f00;font-weight:900;
  padding:9px 20px;border-radius:999px;font-size:15px;box-shadow:0 6px 16px rgba(255,140,40,.35)}
.hambtn{display:grid;place-items:center;width:40px;height:40px;border:none;border-radius:50%;cursor:pointer;font-size:20px;line-height:1;
  color:var(--ink2);background:rgba(255,255,255,.55);box-shadow:0 3px 10px rgba(140,90,20,.16);transition:transform .12s}
.hambtn:active{transform:scale(.9)}
.mobmenu{position:absolute;left:0;right:0;top:100%;display:none;flex-direction:column;padding:6px 16px 14px;gap:2px;
  background:rgba(255,248,236,.98);backdrop-filter:blur(8px);border-bottom:2px solid rgba(255,178,32,.2);box-shadow:0 12px 24px rgba(140,90,20,.15)}
.mobmenu.open{display:flex}
.mobmenu a{padding:12px 8px;font-size:16px;font-weight:800;color:var(--ink2);border-radius:10px}
.mobmenu a.on{color:var(--fire)}
.mobmenu a:active{background:rgba(255,178,32,.12)}
.mobmenu .mm-play{margin-top:8px;text-align:center;color:#3a1f00;background:linear-gradient(120deg,var(--cta1),var(--cta2));box-shadow:0 6px 16px rgba(255,140,40,.35)}
/* ===== footer ===== */
footer{background:#2c2114;color:#cbb99a;text-align:center;padding:34px 20px;font-size:14px}
footer a{color:#ffcf6b;margin:0 10px}
footer a:hover{color:#fff}
footer .cp{margin-top:12px;font-size:12px;color:#8a795c}
/* ===== dark mode (shared) ===== */
:root[data-theme="dark"]{--cream:#16120b;--ink:#f0e7d6;--ink2:#b9a988}
[data-theme="dark"] body{background:#15120b}
[data-theme="dark"] header{background:rgba(20,16,10,.9);border-bottom-color:rgba(255,178,32,.16)}
[data-theme="dark"] .themebtn{background:rgba(255,255,255,.1)}
[data-theme="dark"] .langsw{background:rgba(255,255,255,.1)}
[data-theme="dark"] .hambtn{background:rgba(255,255,255,.1)}
[data-theme="dark"] .mobmenu{background:rgba(20,16,10,.97);border-bottom-color:rgba(255,178,32,.16)}
[data-theme="dark"] .mobmenu a:active{background:rgba(255,255,255,.06)}
[data-theme="dark"] footer{background:#0d0b07}
@media(min-width:720px){.links{display:flex}.miniplay{display:inline-block}.hambtn{display:none}.mobmenu{display:none!important}}
</style>
</body>
</html>
